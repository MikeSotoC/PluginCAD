<Window x:Class="CatastroTools.UI.Views.VentanaPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CatastroTools v2.0" Height="720" Width="860"
        Style="{StaticResource VentanaBase}"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0" Background="{StaticResource BrushPanel}"
                BorderBrush="{StaticResource BrushSeparador}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="16,20,16,16"
                        BorderBrush="{StaticResource BrushSeparador}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="📐 CatastroTools"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource BrushTexto}"/>
                        <TextBlock Text="v2.0 — SUNARP / RNE"
                                   FontSize="10"
                                   Foreground="{StaticResource BrushTextoSec}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,8,8,0">

                        <TextBlock Text="FLUJO DE PROYECTO" Margin="8,8,8,4"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextoSec}"/>

                        <Button Content="🗺  Panel Principal" Tag="panel_principal"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"
                                x:Name="BtnNavPrincipal"/>
                        <Button Content="🔧  Configuración" Tag="panel_config"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>

                        <Separator Style="{StaticResource Separador}" Margin="8,8"/>
                        <TextBlock Text="PASO 1 — PREDIO" Margin="8,0,8,4"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextoSec}"/>
                        <Button Content="📍  Importar Coords UTM" Tag="panel_importar"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>

                        <Separator Style="{StaticResource Separador}" Margin="8,8"/>
                        <TextBlock Text="PASO 2 — VÍAS" Margin="8,0,8,4"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextoSec}"/>
                        <Button Content="🛣  Vía por Eje" Tag="panel_via_eje"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="⊞  Grilla de Vías" Tag="panel_vias_grilla"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="📐  Sección Vial" Tag="panel_seccion"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>

                        <Separator Style="{StaticResource Separador}" Margin="8,8"/>
                        <TextBlock Text="PASO 3 — MANZANAS" Margin="8,0,8,4"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextoSec}"/>
                        <Button Content="🏙  Manzaneo Manual" Tag="panel_manzaneo"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="⊞  Manzaneo Grilla" Tag="panel_manzaneo_grilla"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>

                        <Separator Style="{StaticResource Separador}" Margin="8,8"/>
                        <TextBlock Text="PASO 4 — LOTIZACIÓN" Margin="8,0,8,4"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextoSec}"/>
                        <Button Content="🏠  Lotizar (Recorrido)" Tag="panel_lotizar"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="⊞  Habilitación Grilla" Tag="panel_habilitacion"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="✂  Subdividir Lote" Tag="panel_subdiv"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>

                        <Separator Style="{StaticResource Separador}" Margin="8,8"/>
                        <TextBlock Text="PASO 5 — ETIQUETADO" Margin="8,0,8,4"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextoSec}"/>
                        <Button Content="🏷  Etiquetar Lote" Tag="panel_etiqueta"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="📏  Acotar Completo" Tag="panel_acotar"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="📌  Vértices / Mojones" Tag="panel_vertices"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>

                        <Separator Style="{StaticResource Separador}" Margin="8,8"/>
                        <TextBlock Text="PASO 6 — TABLAS" Margin="8,0,8,4"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextoSec}"/>
                        <Button Content="📋  Cuadro Técnico" Tag="panel_tabla"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="📊  Coordenadas UTM" Tag="panel_tabla_coords"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="🧭  Colindancias" Tag="panel_tabla_colin"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>

                        <Separator Style="{StaticResource Separador}" Margin="8,8"/>
                        <TextBlock Text="PASO 7 — EXPORTAR" Margin="8,0,8,4"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextoSec}"/>
                        <Button Content="🌐  Reporte HTML" Tag="panel_html"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="📄  Exportar CSV" Tag="panel_csv"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button Content="🗑  Purgar Dibujo" Tag="cmd_limpiar"
                                Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>

                        <Separator Style="{StaticResource Separador}" Margin="8,8"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer versión -->
                <Border DockPanel.Dock="Bottom" Padding="16,12"
                        BorderBrush="{StaticResource BrushSeparador}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding PlataformaNombre}"
                                   FontSize="11"
                                   Foreground="{StaticResource BrushTextoSec}"/>
                        <TextBlock Text="{Binding PlataformaVersion}"
                                   FontSize="10"
                                   Foreground="{StaticResource BrushTextoDes}"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ═══ CONTENIDO PRINCIPAL ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra superior -->
            <Border Grid.Row="0" Padding="20,14"
                    BorderBrush="{StaticResource BrushSeparador}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtBreadcrumb"
                                   Text="Panel Principal"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTexto}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource Badge}" Margin="0,0,8,0">
                            <TextBlock Text="{Binding ManzanasCount, StringFormat='🏙 {0} mz'}"
                                       FontSize="11" Foreground="White"/>
                        </Border>
                        <Border Style="{StaticResource BadgeExito}">
                            <TextBlock Text="{Binding LotesCount, StringFormat='🏠 {0} lotes'}"
                                       FontSize="11" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Área de contenido (frame de paneles) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="20">
                <ContentPresenter x:Name="ContenidoPrincipal"/>
            </ScrollViewer>

            <!-- Barra de estado inferior -->
            <Border Grid.Row="2" Padding="20,10"
                    Background="{StaticResource BrushPanel}"
                    BorderBrush="{StaticResource BrushSeparador}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="TxtEstado"
                               Text="Listo."
                               Foreground="{StaticResource BrushTextoSec}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding ZonaUTM, StringFormat='🌍 UTM {0}'}"
                                   Foreground="{StaticResource BrushTextoSec}"
                                   FontSize="11" Margin="0,0,16,0"
                                   VerticalAlignment="Center"/>
                        <Button Content="Cerrar" Width="80" Height="28"
                                Style="{StaticResource BtnSecundario}"
                                Click="BtnCerrar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
