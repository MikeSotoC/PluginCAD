<Window x:Class="CatastroTools.UI.Views.VentanaPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CatastroTools"
        Width="340"
        Height="520"
        Background="#1E2430"
        Foreground="#E2E8F0"
        FontFamily="Segoe UI"
        FontSize="12"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Grid.Row="0"
                Background="#252D3E"
                BorderBrush="#334155"
                BorderThickness="1"
                Padding="10">

            <StackPanel>
                <TextBlock Text="CatastroTools"
                           FontSize="16"
                           FontWeight="Bold"/>

                <TextBlock Text="Sistema Catastral Peru"
                           FontSize="10"
                           Foreground="#94A3B8"/>
            </StackPanel>

        </Border>

        <!-- BOTONES -->

        <ScrollViewer Grid.Row="1"
                      Margin="0,10,0,10">

            <StackPanel>

                <Button Content="Importar Coordenadas"
                        Tag="panel_importar"
                        Click="NavBtn_Click"
                        Height="32"
                        Margin="0,0,0,6"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Via por Eje"
                        Tag="panel_via_eje"
                        Click="NavBtn_Click"
                        Height="32"
                        Margin="0,0,0,6"
                        Background="#2D3748"
                        Foreground="White"
                        BorderBrush="#3D4F6B"/>

                <Button Content="Manzaneo"
                        Tag="panel_manzaneo"
                        Click="NavBtn_Click"
                        Height="32"
                        Margin="0,0,0,6"
                        Background="#2D3748"
                        Foreground="White"
                        BorderBrush="#3D4F6B"/>

                <Button Content="Lotizar"
                        Tag="panel_lotizar"
                        Click="NavBtn_Click"
                        Height="32"
                        Margin="0,0,0,6"
                        Background="#2D3748"
                        Foreground="White"
                        BorderBrush="#3D4F6B"/>

                <Button Content="Tabla Tecnica"
                        Tag="panel_tabla"
                        Click="NavBtn_Click"
                        Height="32"
                        Margin="0,0,0,6"
                        Background="#2D3748"
                        Foreground="White"
                        BorderBrush="#3D4F6B"/>

                <Button Content="Exportar HTML"
                        Tag="panel_html"
                        Click="NavBtn_Click"
                        Height="32"
                        Margin="0,0,0,6"
                        Background="#2D3748"
                        Foreground="White"
                        BorderBrush="#3D4F6B"/>

            </StackPanel>

        </ScrollViewer>

        <!-- FOOTER -->

        <Border Grid.Row="2"
                Background="#252D3E"
                BorderBrush="#334155"
                BorderThickness="1"
                Padding="8">

            <DockPanel>

                <TextBlock x:Name="TxtEstado"
                           Text="Listo"
                           VerticalAlignment="Center"
                           Foreground="#94A3B8"/>

                <Button Content="X"
                        Width="22"
                        Height="22"
                        DockPanel.Dock="Right"
                        Click="BtnCerrar_Click"/>

            </DockPanel>

        </Border>

    </Grid>

</Window>