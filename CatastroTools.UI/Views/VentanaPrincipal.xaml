<Window x:Class="CatastroTools.UI.Views.VentanaPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CatastroTools" Height="520" Width="340"
        Style="{StaticResource VentanaBase}"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="False"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ CABECERA ═══ -->
        <Border Grid.Row="0" Padding="10,8"
                BorderBrush="{StaticResource BrushSeparador}"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📐 CatastroTools"
                               FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource BrushTexto}"/>
                    <TextBlock Text=" v2.0"
                               FontSize="9"
                               Foreground="{StaticResource BrushTextoSec}"
                               Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding ManzanasCount, StringFormat='🏙{0}'}"
                               FontSize="9" Foreground="{StaticResource BrushTextoSec}"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding LotesCount, StringFormat='🏠{0}'}"
                               FontSize="9" Foreground="{StaticResource BrushTextoSec}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ BOTONES DE COMANDOS ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="8">
            <StackPanel>
                <!-- PREDIO -->
                <TextBlock Text="PREDIO" Margin="0,4,0,4"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoSec}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="📍 UTM" Tag="panel_importar"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Importar coordenadas UTM"/>
                </WrapPanel>

                <!-- VÍAS -->
                <TextBlock Text="VÍAS" Margin="0,8,0,4"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoSec}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="🛣 Eje" Tag="panel_via_eje"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Vía por eje"/>
                    <Button Content="⊞ Grilla" Tag="panel_vias_grilla"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Grilla de vías"/>
                    <Button Content="📐 Sec" Tag="panel_seccion"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Sección vial"/>
                </WrapPanel>

                <!-- MANZANAS -->
                <TextBlock Text="MANZANAS" Margin="0,8,0,4"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoSec}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="🏙 Manual" Tag="panel_manzaneo"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Manzaneo manual"/>
                    <Button Content="⊞ Grilla" Tag="panel_manzaneo_grilla"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Manzaneo por grilla"/>
                </WrapPanel>

                <!-- LOTIZACIÓN -->
                <TextBlock Text="LOTIZACIÓN" Margin="0,8,0,4"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoSec}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="🏠 Recorr" Tag="panel_lotizar"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Lotizar por recorrido"/>
                    <Button Content="⊞ Hab" Tag="panel_habilitacion"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Habilitación urbana"/>
                    <Button Content="✂ Dividir" Tag="panel_subdiv"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Subdividir lote"/>
                </WrapPanel>

                <!-- ETIQUETADO -->
                <TextBlock Text="ETIQUETADO" Margin="0,8,0,4"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoSec}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="🏷 Lote" Tag="panel_etiqueta"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Etiquetar lote"/>
                    <Button Content="📏 Acotar" Tag="panel_acotar"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Acotar completo"/>
                    <Button Content="📌 Vert" Tag="panel_vertices"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Marcar vértices"/>
                </WrapPanel>

                <!-- TABLAS -->
                <TextBlock Text="TABLAS" Margin="0,8,0,4"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoSec}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="📋 Técn" Tag="panel_tabla"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Tabla datos técnicos"/>
                    <Button Content="📊 Coord" Tag="panel_tabla_coords"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Tabla coordenadas"/>
                    <Button Content="🧭 Colin" Tag="panel_tabla_colin"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Tabla colindancias"/>
                </WrapPanel>

                <!-- EXPORTAR -->
                <TextBlock Text="EXPORTAR" Margin="0,8,0,4"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoSec}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="🌐 HTML" Tag="panel_html"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Exportar HTML"/>
                    <Button Content="📄 CSV" Tag="panel_csv"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Exportar CSV"/>
                    <Button Content="🗑 Limpiar" Tag="cmd_limpiar"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Limpiar dibujo"/>
                </WrapPanel>

                <!-- CONFIG -->
                <TextBlock Text="OPCIONES" Margin="0,8,0,4"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoSec}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="🔧 Config" Tag="panel_config"
                            Style="{StaticResource BtnCompacto}" Click="NavBtn_Click"
                            ToolTip="Configuración"/>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ ESTADO ═══ -->
        <Border Grid.Row="2" Padding="8,6"
                Background="{StaticResource BrushPanel}"
                BorderBrush="{StaticResource BrushSeparador}"
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="TxtEstado"
                           Text="Listo"
                           Foreground="{StaticResource BrushTextoSec}"
                           FontSize="9" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ZonaUTM, StringFormat='UTM {0}'}"
                               Foreground="{StaticResource BrushTextoSec}"
                               FontSize="8" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Width="22" Height="22"
                            Style="{StaticResource BtnIcono}"
                            Click="BtnCerrar_Click"
                            ToolTip="Cerrar panel"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
