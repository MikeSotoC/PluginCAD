<UserControl x:Class="CatastroTools.UI.Views.PanelPrincipal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>

        <!-- Header -->
        <StackPanel Margin="0,0,0,24">
            <TextBlock Style="{StaticResource TextoTitulo}"
                       Text="Sistema Catastral — CatastroTools v2.0"/>
            <TextBlock Style="{StaticResource TextoSubtitulo}"
                       Text="Habilitaciones Urbanas · SUNARP · RNE GH.020 · Perú"/>
        </StackPanel>

        <!-- Flujo de trabajo -->
        <TextBlock Style="{StaticResource TextoSeccion}" Text="FLUJO DE TRABAJO"/>

        <Border Style="{StaticResource Tarjeta}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Paso 1 -->
                <StackPanel Grid.Column="0">
                    <Border Background="#1A3B82F6" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="📍" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Text="1. PREDIO" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF3B82F6" HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="Importar coords UTM" FontSize="10"
                                       Foreground="{StaticResource BrushTextoSec}"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Flecha -->
                <TextBlock Grid.Column="1" Text="→" FontSize="18"
                           Foreground="{StaticResource BrushTextoSec}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Paso 2 -->
                <StackPanel Grid.Column="2">
                    <Border Background="#1AFBBF24" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="🛣" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Text="2. VÍAS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFFBBF24" HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="Trazar red vial" FontSize="10"
                                       Foreground="{StaticResource BrushTextoSec}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Flecha -->
                <TextBlock Grid.Column="3" Text="→" FontSize="18"
                           Foreground="{StaticResource BrushTextoSec}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Paso 3 -->
                <StackPanel Grid.Column="4">
                    <Border Background="#1A10B981" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="🏙" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Text="3. MANZANAS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF10B981" HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="Definir manzanas" FontSize="10"
                                       Foreground="{StaticResource BrushTextoSec}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Flecha -->
                <TextBlock Grid.Column="5" Text="→" FontSize="18"
                           Foreground="{StaticResource BrushTextoSec}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Paso 4 -->
                <StackPanel Grid.Column="6">
                    <Border Background="#1AEF4444" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="🏠" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Text="4. LOTES" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFEF4444" HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="Lotizar + etiquetar" FontSize="10"
                                       Foreground="{StaticResource BrushTextoSec}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Flecha -->
                <TextBlock Grid.Column="7" Text="→" FontSize="18"
                           Foreground="{StaticResource BrushTextoSec}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Paso 5 -->
                <StackPanel Grid.Column="8">
                    <Border Background="#1A8B5CF6" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="📋" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Text="5. DOCS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF8B5CF6" HorizontalAlignment="Center"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="Tablas + Reporte" FontSize="10"
                                       Foreground="{StaticResource BrushTextoSec}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Accesos rápidos -->
        <TextBlock Style="{StaticResource TextoSeccion}" Text="ACCESOS RÁPIDOS"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Fila 1 -->
            <Button Grid.Column="0" Grid.Row="0" Tag="panel_importar"
                    Style="{StaticResource TarjetaBtn}" Click="AccesoRapido_Click">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="📍  Importar Coords UTM" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTexto}" FontSize="13"/>
                    <TextBlock Text="Crear lote desde coordenadas UTM" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Grid.Row="0" Tag="panel_lotizar"
                    Style="{StaticResource TarjetaBtn}" Click="AccesoRapido_Click">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="🏠  CT-LOTIZAR" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTexto}" FontSize="13"/>
                    <TextBlock Text="Numerar + Etiquetar + Colindancias" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4" Grid.Row="0" Tag="panel_tabla"
                    Style="{StaticResource TarjetaBtn}" Click="AccesoRapido_Click">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="📋  Cuadro Técnico SUNARP" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTexto}" FontSize="13"/>
                    <TextBlock Text="Tabla de datos del predio" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <!-- Fila 2 -->
            <Button Grid.Column="0" Grid.Row="2" Tag="panel_via_eje"
                    Style="{StaticResource TarjetaBtn}" Click="AccesoRapido_Click">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="🛣  Vía por Eje" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTexto}" FontSize="13"/>
                    <TextBlock Text="RNE GH.020 — anchos estándar" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Grid.Row="2" Tag="panel_manzaneo_grilla"
                    Style="{StaticResource TarjetaBtn}" Click="AccesoRapido_Click">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="⊞  Manzaneo Grilla" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTexto}" FontSize="13"/>
                    <TextBlock Text="Generar manzanas automáticamente" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4" Grid.Row="2" Tag="panel_html"
                    Style="{StaticResource TarjetaBtn}" Click="AccesoRapido_Click">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="🌐  Reporte HTML" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTexto}" FontSize="13"/>
                    <TextBlock Text="Expediente técnico para SUNARP" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Estado del proyecto -->
        <TextBlock Style="{StaticResource TextoSeccion}" Text="PROYECTO ACTUAL"/>
        <Border Style="{StaticResource Tarjeta}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtManzanas" Text="0"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Manzanas" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtLotes" Text="0"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource BrushExito}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Lotes" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtVias" Text="0"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource BrushAdvert}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Vías" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtAreaTotal" Text="—"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource BrushTexto}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Área total (m²)" FontSize="11"
                               Foreground="{StaticResource BrushTextoSec}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

    </StackPanel>
</UserControl>
