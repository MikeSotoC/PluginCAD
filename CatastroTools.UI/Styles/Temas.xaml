<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- COLORES -->

    <Color x:Key="ColorFondo">#1E2430</Color>
    <Color x:Key="ColorPanel">#252D3E</Color>
    <Color x:Key="ColorTarjeta">#2D3748</Color>
    <Color x:Key="ColorBorde">#3D4F6B</Color>
    <Color x:Key="ColorAccent">#3B82F6</Color>
    <Color x:Key="ColorExito">#10B981</Color>
    <Color x:Key="ColorAdvertencia">#FBBF24</Color>
    <Color x:Key="ColorError">#EF4444</Color>
    <Color x:Key="ColorTexto">#E2E8F0</Color>
    <Color x:Key="ColorTextoSec">#94A3B8</Color>
    <Color x:Key="ColorTextoDes">#4A5568</Color>
    <Color x:Key="ColorInput">#1A2338</Color>
    <Color x:Key="ColorSeparador">#334155</Color>

    <!-- BRUSHES -->

    <SolidColorBrush x:Key="BrushFondo" Color="{StaticResource ColorFondo}"/>
    <SolidColorBrush x:Key="BrushPanel" Color="{StaticResource ColorPanel}"/>
    <SolidColorBrush x:Key="BrushTarjeta" Color="{StaticResource ColorTarjeta}"/>
    <SolidColorBrush x:Key="BrushBorde" Color="{StaticResource ColorBorde}"/>
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushExito" Color="{StaticResource ColorExito}"/>
    <SolidColorBrush x:Key="BrushAdvert" Color="{StaticResource ColorAdvertencia}"/>
    <SolidColorBrush x:Key="BrushError" Color="{StaticResource ColorError}"/>
    <SolidColorBrush x:Key="BrushTexto" Color="{StaticResource ColorTexto}"/>
    <SolidColorBrush x:Key="BrushTextoSec" Color="{StaticResource ColorTextoSec}"/>
    <SolidColorBrush x:Key="BrushTextoDes" Color="{StaticResource ColorTextoDes}"/>
    <SolidColorBrush x:Key="BrushInput" Color="{StaticResource ColorInput}"/>
    <SolidColorBrush x:Key="BrushSeparador" Color="{StaticResource ColorSeparador}"/>

    <!-- WINDOW -->

    <Style x:Key="VentanaBase" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BrushFondo}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTexto}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- TEXTOS -->

    <Style x:Key="TextoTitulo" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTexto}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="TextoSubtitulo" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextoSec}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style x:Key="TextoSeccion" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,12,0,6"/>
    </Style>

    <!-- TARJETAS -->

    <Style x:Key="Tarjeta" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushTarjeta}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorde}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- BOTON PRINCIPAL -->

    <Style x:Key="BtnPrimario" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- BOTON COMPACTO -->

    <Style x:Key="BtnCompacto" TargetType="Button">
        <Setter Property="Height" Value="24"/>
        <Setter Property="MinWidth" Value="60"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTexto}"/>
        <Setter Property="Background" Value="{StaticResource BrushInput}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushSeparador}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- BOTON ICONO -->

    <Style x:Key="BtnIcono" TargetType="Button">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Background" Value="{StaticResource BrushInput}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTexto}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushSeparador}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>